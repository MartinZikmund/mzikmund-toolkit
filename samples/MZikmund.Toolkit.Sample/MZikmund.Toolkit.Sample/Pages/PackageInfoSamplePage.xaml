<Page x:Class="MZikmund.Toolkit.Sample.PackageInfoSamplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:MZikmund.Toolkit.Sample">

  <ScrollViewer Padding="24">
    <StackPanel Spacing="16" MaxWidth="800">
      <TextBlock Text="GeneratedPackageInfo source generator"
                 Style="{ThemeResource TitleTextBlockStyle}" />

      <TextBlock Text="The MZikmund.Toolkit.SourceGenerators analyzer ships alongside the toolkit and emits a GeneratedPackageInfo class into each consuming assembly. The class exposes a static GetPackages() returning a list of (Id, Version) pairs for the user-facing references in the project — handy for an About / Third-party software dialog."
                 TextWrapping="Wrap"
                 Style="{ThemeResource BodyTextBlockStyle}" />

      <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="Sample app's references"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />

          <TextBlock x:Name="CountText" Style="{ThemeResource BodyStrongTextBlockStyle}" />

          <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="4"
                  MaxHeight="320">
            <ScrollViewer>
              <ItemsControl x:Name="PackagesList" Padding="8" />
            </ScrollViewer>
          </Border>
        </StackPanel>
      </Border>

      <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="Code Sample"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />

          <TextBlock FontFamily="Consolas" TextWrapping="Wrap">
            <Run>using MZikmund.Toolkit.Generated;</Run><LineBreak />
            <LineBreak />
            <Run>foreach (var package in GeneratedPackageInfo.GetPackages())</Run><LineBreak />
            <Run>{</Run><LineBreak />
            <Run>    Console.WriteLine($"{package.Id} {package.Version}");</Run><LineBreak />
            <Run>}</Run>
          </TextBlock>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
