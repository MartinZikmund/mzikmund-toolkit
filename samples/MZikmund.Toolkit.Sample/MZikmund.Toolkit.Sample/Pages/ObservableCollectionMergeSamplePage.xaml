<Page x:Class="MZikmund.Toolkit.Sample.ObservableCollectionMergeSamplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:MZikmund.Toolkit.Sample">

  <ScrollViewer Padding="24">
    <StackPanel Spacing="16" MaxWidth="800">
      <TextBlock Text="ObservableCollection.MergeWith"
                 Style="{ThemeResource TitleTextBlockStyle}" />

      <TextBlock Text="MergeWith synchronizes an ObservableCollection with a source list using minimal Insert/RemoveAt/Move operations. Bound list controls animate the per-item changes instead of flickering on a Clear+Add reset."
                 TextWrapping="Wrap"
                 Style="{ThemeResource BodyTextBlockStyle}" />

      <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="Live Demo"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />

          <TextBlock Text="Edit the desired sequence below (one item per line) and merge it into the live collection. Watch the ListView animate insertions, removals, and reorders rather than fully resetting."
                     TextWrapping="Wrap"
                     Style="{ThemeResource BodyTextBlockStyle}" />

          <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="8">
              <TextBlock Text="Desired sequence"
                         Style="{ThemeResource BodyStrongTextBlockStyle}" />
              <TextBox x:Name="DesiredSequenceInput"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       Height="200" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
              <TextBlock Text="Live collection"
                         Style="{ThemeResource BodyStrongTextBlockStyle}" />
              <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Height="200">
                <ListView x:Name="LiveCollectionList"
                          SelectionMode="None" />
              </Border>
            </StackPanel>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Merge" Click="Merge_Click" Style="{ThemeResource AccentButtonStyle}" />
            <Button Content="Shuffle source" Click="Shuffle_Click" />
            <Button Content="Reset" Click="Reset_Click" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="Code Sample"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />

          <TextBlock FontFamily="Consolas" TextWrapping="Wrap">
            <Run>using MZikmund.Toolkit.WinUI.Extensions;</Run><LineBreak />
            <LineBreak />
            <Run>var live = new ObservableCollection&lt;string&gt; { "A", "B", "C" };</Run><LineBreak />
            <Run>var next = new[] { "C", "A", "D" };</Run><LineBreak />
            <LineBreak />
            <Run>// Reorders A, removes B, inserts D — no full reset.</Run><LineBreak />
            <Run>live.MergeWith(next);</Run>
          </TextBlock>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
