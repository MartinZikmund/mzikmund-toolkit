<Page x:Class="MZikmund.Toolkit.Sample.XamlRootProviderSamplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:MZikmund.Toolkit.Sample">

  <ScrollViewer Padding="24">
    <StackPanel Spacing="16" MaxWidth="800">
      <TextBlock Text="XamlRoot Provider"
                 Style="{ThemeResource TitleTextBlockStyle}" />
      
      <TextBlock TextWrapping="Wrap"
                 Style="{ThemeResource BodyTextBlockStyle}">
        <Run>The IXamlRootProvider interface provides centralized access to the XamlRoot instance, which is required for displaying dialogs, popups, and other UI elements. This is particularly useful in services or view models that don't have direct access to the UI tree.</Run>
      </TextBlock>
      
      <!-- Understanding XamlRoot -->
      <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="What is XamlRoot?"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />
          
          <TextBlock TextWrapping="Wrap"
                     Style="{ThemeResource BodyTextBlockStyle}">
            <Run>XamlRoot represents the root of a XAML visual tree. In WinUI 3, ContentDialog and other UI elements require a valid XamlRoot to determine which window they should be displayed in. This is especially important in multi-window scenarios.</Run>
          </TextBlock>
        </StackPanel>
      </Border>
      
      <!-- XamlRoot Information -->
      <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="Current XamlRoot Information"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />
          
          <Button Content="Get XamlRoot Info" Click="GetXamlRootInfo_Click" />
          
          <TextBlock x:Name="XamlRootInfo"
                     Text="Click to get XamlRoot information"
                     TextWrapping="Wrap"
                     Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        </StackPanel>
      </Border>
      
      <!-- Usage Example -->
      <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="Usage with Dialog"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />
          
          <TextBlock Text="Show a dialog using the XamlRoot from this page:"
                     TextWrapping="Wrap"
                     Style="{ThemeResource BodyTextBlockStyle}" />
          
          <Button Content="Show Dialog" Click="ShowDialogWithXamlRoot_Click" />
          
          <TextBlock x:Name="DialogResult"
                     Text="No dialog shown yet"
                     Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        </StackPanel>
      </Border>
      
      <!-- Code Sample -->
      <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="Code Sample"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />
          
          <TextBlock FontFamily="Consolas" TextWrapping="Wrap">
            <Run>using MZikmund.Toolkit.WinUI.Infrastructure;</Run><LineBreak />
            <LineBreak />
            <Run>// Implement IXamlRootProvider in your main window or page</Run><LineBreak />
            <Run>public class MainWindow : Window, IXamlRootProvider</Run><LineBreak />
            <Run>{</Run><LineBreak />
            <Run>    public XamlRoot XamlRoot => Content.XamlRoot;</Run><LineBreak />
            <Run>}</Run><LineBreak />
            <LineBreak />
            <Run>// Use in a service or view model</Run><LineBreak />
            <Run>public class MyService</Run><LineBreak />
            <Run>{</Run><LineBreak />
            <Run>    private readonly IXamlRootProvider _xamlRootProvider;</Run><LineBreak />
            <LineBreak />
            <Run>    public async Task ShowDialogAsync()</Run><LineBreak />
            <Run>    {</Run><LineBreak />
            <Run>        var dialog = new ContentDialog</Run><LineBreak />
            <Run>        {</Run><LineBreak />
            <Run>            Title = "Example",</Run><LineBreak />
            <Run>            Content = "Message",</Run><LineBreak />
            <Run>            PrimaryButtonText = "OK",</Run><LineBreak />
            <Run>            XamlRoot = _xamlRootProvider.XamlRoot</Run><LineBreak />
            <Run>        };</Run><LineBreak />
            <Run>        await dialog.ShowAsync();</Run><LineBreak />
            <Run>    }</Run><LineBreak />
            <Run>}</Run>
          </TextBlock>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
